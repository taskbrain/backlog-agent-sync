# backlog-agent-sync — Codex CLI wiring 設定例（MCP のみ）
#
# install/install-codex.sh が ~/.codex/config.toml へ自動マージする。
# 手動で導入する場合は本ファイルの内容を ~/.codex/config.toml へ追記すること。
#
# 【重要】フックは config.toml の [[hooks.*]] では定義しない。
# Codex CLI（0.137.0 実機検証）は config.toml 内のフック定義を trust せず
# 黙ってスキップするため機能しない。正しい方式:
#   1. フック定義を ~/.codex/hooks.json に置く（例: codex/hooks.json.example）
#   2. config.toml の
#        [hooks.state."<hooks.jsonの絶対パス>:<event_label>:<groupIndex>:<handlerIndex>"]
#      に trusted_hash = "sha256:..." を登録する（event_label は snake_case:
#      session_start / user_prompt_submit / post_tool_use / subagent_stop / stop）
# このマージとハッシュ計算は install/install-codex.sh（内部で
# install/codex-register.mjs を呼ぶ）が自動で行う。手動での承認は不要。
#
# 前提（シェル環境変数。値を config へ直接書かない・コミット禁止。
# フックのサブプロセスへは親シェルの環境変数がそのまま渡る）:
#   export BACKLOG_DOMAIN="your-space.backlog.com"   # または your-space.backlog.jp
#   export BACKLOG_API_KEY="..."                     # 個人 API キー
#   export BACKLOG_PROJECT="PROJ"                    # フック CLI が使用

# --- Backlog MCP（意味的同期 / ceiling） ---
# env_vars: ローカルシェルの環境変数を MCP サーバへ転送する whitelist（値は書かない）
# ENABLE_TOOLSETS: 露出を space,project,issue に限定（wiki/git/document/notifications 無効）
[mcp_servers.backlog]
command = "npx"
args = ["backlog-mcp-server@0.12.0"]
env = { ENABLE_TOOLSETS = "space,project,issue" }
env_vars = ["BACKLOG_DOMAIN", "BACKLOG_API_KEY"]
